# Copy to .env and fill in. .env is gitignored — never commit real secrets.

DATABASE_URL="file:./lotscout.db"

# Supabase — scripts use SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY;
# the Next.js app uses NEXT_PUBLIC_SUPABASE_URL + (anon or service role) key.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Email notifications (Composio → Gmail). Optional; omit to disable emails.
COMPOSIO_API="https://backend.composio.dev/api/v2/actions/GMAIL_SEND_EMAIL/execute"
COMPOSIO_KEY="your-composio-key"
GMAIL_CONNECTION="your-gmail-connected-account-id"
NOTIFICATION_EMAIL="you@example.com"

# MiniMax (optional AI analysis)
MINIMAX_API="https://api.minimax.io/v1/chat/completions"
MINIMAX_KEY="your-minimax-key"

# RPR (Realtors Property Resource) comps scraper
RPR_USERNAME="you@example.com"
RPR_PASSWORD="your-rpr-password"
